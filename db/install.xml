<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/vbs_schedule/db" VERSION="20260713" COMMENT="Schema for local_vbs_schedule plugin"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="vbs_schedule_pref" COMMENT="Per-user schedule display preferences">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK to mdl_user.id — unique per user"/>
        <FIELD NAME="view_mode" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="month" SEQUENCE="false" COMMENT="Preferred calendar view: month, week, or list"/>
        <FIELD NAME="show_class" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" SEQUENCE="false" COMMENT="1 = show class events, 0 = hide"/>
        <FIELD NAME="show_exam" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" SEQUENCE="false" COMMENT="1 = show exam events, 0 = hide"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Unix timestamp of last update"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="unique" FIELDS="userid"/>
        <KEY NAME="fk_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
